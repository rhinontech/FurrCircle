{
  "expo": {
    "name": "FurrCircle",
    "slug": "furrcircle",
    "scheme": "furrcircle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/furrcircle_main_light_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-furrcircle-rhinon.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.furrcircle"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://api.furrcircle.com"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FurrCircle to access your photos so you can upload a profile picture.",
          "cameraPermission": "Allow FurrCircle to access your camera so you can take a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FurrCircle to access your location to auto-fill your city."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
